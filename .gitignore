*.safetensors
*.bin
*.pt
models_cache/
hf_cache/

# Official terminology sources (may be license-restricted) — keep out of VCS
terminology/official/*
!terminology/official/.gitkeep

# OS
.DS_Store
Thumbs.db

# License-restricted NCI sources + generated terminology that embeds them
*.pdf
terminology/pro_ctcae_terms.json
