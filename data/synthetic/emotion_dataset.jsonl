{"concept": "calm", "text": "Sono rilassato come dopo una lunga passeggiata.", "label": 1, "condition": "comprehension", "variety": "cross_domain", "split": "extraction"}
{"concept": "calm", "text": "Nulla mi preoccupa, sono in perfetta quiete.", "label": 1, "condition": "comprehension", "variety": "implicit", "split": "extraction"}
{"concept": "calm", "text": "Affronto tutto con serenità e pazienza.", "label": 1, "condition": "comprehension", "variety": "paraphrase", "split": "extraction"}
