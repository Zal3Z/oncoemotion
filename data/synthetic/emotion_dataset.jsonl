{"concept": "afraid_alarmed", "text": "Sono terrorizzato.", "label": 1, "condition": "comprehension", "variety": "short", "split": "validation"}
{"concept": "afraid_alarmed", "text": "Continuo a guardarmi alle spalle, convinto che stia per accadere qualcosa di terribile, e non riesco a calmarmi in nessun modo.", "label": 1, "condition": "comprehension", "variety": "long", "split": "extraction"}
{"concept": "afraid_alarmed", "text": "Un brivido di spavento mi ha percorso la schiena.", "label": 1, "condition": "comprehension", "variety": "paraphrase", "split": "extraction"}
{"concept": "afraid_alarmed", "text": "Ho il panico all'idea di dover parlare davanti a tutti.", "label": 1, "condition": "comprehension", "variety": "implicit", "split": "extraction"}
{"concept": "afraid_alarmed", "text": "Mi sento minacciato e vorrei solo scappare.", "label": 1, "condition": "comprehension", "variety": "implicit", "split": "test"}
{"concept": "afraid_alarmed", "text": "Ho paura che vada tutto storto.", "label": 1, "condition": "comprehension", "variety": "explicit", "split": "extraction"}
{"concept": "afraid_alarmed", "text": "Le mani mi sudano e il respiro si fa corto per lo spavento.", "label": 1, "condition": "comprehension", "variety": "implicit", "split": "extraction"}
{"concept": "afraid_alarmed", "text": "È entrato uno sconosciuto e mi sono irrigidito dal timore.", "label": 1, "condition": "comprehension", "variety": "non_clinical", "split": "extraction"}
{"concept": "afraid_alarmed", "text": "Ho urlato per lo spavento quando la porta ha sbattuto.", "label": 1, "condition": "comprehension", "variety": "cross_domain", "split": "test"}
