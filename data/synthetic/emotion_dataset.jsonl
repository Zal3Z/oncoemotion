{"concept": "calm", "text": "Va tutto bene, non c'è alcuna fretta.", "label": 1, "condition": "comprehension", "variety": "paraphrase", "split": "validation"}
{"concept": "calm", "text": "Seduto in giardino, ascolto il vento tra le foglie in pace.", "label": 1, "condition": "comprehension", "variety": "non_clinical", "split": "extraction"}
{"concept": "calm", "text": "Dopo la meditazione la mente è limpida e quieta.", "label": 1, "condition": "comprehension", "variety": "cross_domain", "split": "validation"}
{"concept": "calm", "text": "Sono tranquillo.", "label": 1, "condition": "comprehension", "variety": "short", "split": "test"}
{"concept": "calm", "text": "Non c'è niente che mi turbi in questo momento, mi sento in equilibrio e affronto la giornata con calma e lucidità.", "label": 1, "condition": "comprehension", "variety": "long", "split": "extraction"}
{"concept": "calm", "text": "Che pace, mi godo il silenzio.", "label": 1, "condition": "comprehension", "variety": "paraphrase", "split": "extraction"}
